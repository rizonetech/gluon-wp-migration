# =============================================================================
# Gluon WP Migration — plugin repository
# =============================================================================

# -----------------------------------------------------------------------------
# Plugin runtime / generated content
# -----------------------------------------------------------------------------
# The plugin's temp/status folder is `runtime/`. Track the deny-stub files
# (.htaccess, web.config, index.php) so the directory deploys correctly;
# ignore every other file the plugin writes there at runtime.
runtime/*
!runtime/.htaccess
!runtime/web.config
!runtime/index.php

# -----------------------------------------------------------------------------
# Build / dependency artifacts
# -----------------------------------------------------------------------------
node_modules/
.cache/
dist/
build/
coverage/
.phpunit.result.cache
.phpcs-cache

# Composer-managed deps. Per TODO-A §2.2 the vendor/ tree is committed so
# release ZIPs are self-contained; uncomment the line below only if a
# build step rewrites vendor/ from composer.lock at release time.
# /vendor/

# -----------------------------------------------------------------------------
# Release artifacts (built ZIPs and Gluon archives the plugin produces in tests)
# -----------------------------------------------------------------------------
*.zip
*.gwpack

# -----------------------------------------------------------------------------
# Translations — compiled .mo files; .pot/.po stay tracked
# -----------------------------------------------------------------------------
languages/*.mo

# -----------------------------------------------------------------------------
# Logs / debug
# -----------------------------------------------------------------------------
*.log
debug.log

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo
*.bak
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Secrets — defense in depth
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
auth.json
